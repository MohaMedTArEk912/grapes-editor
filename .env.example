OPENROUTER_API_KEY=your_openrouter_api_key_here
PORT=3001

# LLM Provider Configuration
# Set QWEN_ENABLED=true to use local Qwen model
# Set QWEN_ENABLED=false or leave unset to use OpenRouter API
QWEN_ENABLED=true
QWEN_URL=http://localhost:8000
QWEN_TIMEOUT=30000

# Fallback behavior
# Set FALLBACK_TO_OPENROUTER=true to automatically fallback to OpenRouter if Qwen is unavailable
FALLBACK_TO_OPENROUTER=true
